{{ ansible_managed | comment }}

[Unit]
Description=NVMe Exporter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ nvme_exporter_system_user }}
Group={{ nvme_exporter_system_group }}
ExecStart={{ nvme_exporter_binary_install_dir }}/nvme_exporter \
{% if nvme_exporter_web_listen_address is iterable and
      nvme_exporter_web_listen_address is not mapping and
      nvme_exporter_web_listen_address is not string %}
{%   for address in nvme_exporter_web_listen_address %}
    '--web.listen-address={{ address }}' \
{%   endfor %}
{% else %}
    '--web.listen-address={{ nvme_exporter_web_listen_address }}' \
{% endif %}
{% if nvme_exporter_disable_defaults | bool %}
    '--collector.disable-defaults' \
{% endif %}
{% for collector in nvme_exporter_enabled_collectors %}
    '--collector.{{ collector }}' \
{% endfor %}
{% for collector in nvme_exporter_disabled_collectors %}
    '--no-collector.{{ collector }}' \
{% endfor %}
    '--web.telemetry-path={{ nvme_exporter_web_telemetry_path }}'

SyslogIdentifier=nvme_exporter
Restart=always
RestartSec=1
StartLimitInterval=0

{% set ns = namespace(protect_home = 'yes') %}
{% for m in ansible_facts['mounts'] if m.mount.startswith('/home') %}
{%   set ns.protect_home = 'read-only' %}
{% endfor %}
ProtectHome={{ ns.protect_home }}
NoNewPrivileges=yes

{% if (ansible_facts.packages.systemd | first).version is version('232', '>=') %}
ProtectSystem=strict
ProtectControlGroups=true
ProtectKernelModules=true
ProtectKernelTunables=yes
{% else %}
ProtectSystem=full
{% endif %}

[Install]
WantedBy=multi-user.target
